Bootstrap: localimage
From: containers/base.sif

%post
    export DEBIAN_FRONTEND=noninteractive

    # git needed to pip-install desc from GitHub
    apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

    # TensorFlow 2.14 with CUDA support (desc backend)
    python -m pip install --no-cache-dir \
        "tensorflow==2.14.*"

    # desc and its specific dependency
    python -m pip install --no-cache-dir \
        "python-igraph==0.10.8" \
        "git+https://github.com/johnarevalo/desc.git"

    # HPO dependencies (scib-metrics already in base)
    # TF 2.14 pins ml_dtypes==0.2.0, which breaks JAX>=0.5. Install compatible JAX.
    # setuptools needed for pkg_resources (required by louvain import)
    python -m pip install --no-cache-dir \
        optuna \
        "jax[cuda12]==0.4.30" \
        "jaxlib[cuda12]==0.4.30" \
        "setuptools<81"

    # LAST: force cuDNN 9.8 — torch/jax pin 9.1 but jaxlib needs 9.8.
    # Must be last so nothing can downgrade it.
    python -m pip install --no-cache-dir --force-reinstall --no-deps \
        "nvidia-cudnn-cu12==9.8.0.87"
